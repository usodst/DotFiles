{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwn3:30b",
  "mcp": {
    "Azure": {
      "type": "local",
      "command": ["npx", "-y", "@azure/mcp@latest", "server", "start"],
      "enabled": true
    },
    "AzureDevOps": {
      "type": "local",
      "command": ["npx", "-y", "@azure-devops/mcp", ""],
      "enabled": true
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3:30b": {
          "name": "Qwen3",
          "tools": true,
          "thinking": true
        },
        "gpt-oss:20b": {
          "name": "GPT",
          "tools": true,
          "thinking": true
        }
      }
    }
  }
}
