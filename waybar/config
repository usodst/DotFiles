        "custom/media-next"
      ]
    },
    "custom/media-previous": {
      "format": " ůįíģ ",
      "tooltip": false,
      "on-click": "playerctl previous"
    },
    "custom/media-play": {
      "exec": "if [ \"$(playerctl status 2>/dev/null)\" = \"Playing\" ]; then echo ' ůįŹ§ '; else echo ' ůįźä '; fi",
      "interval": 1,
      "tooltip": false,
      "on-click": "playerctl play-pause"
    },
    "custom/media-title": {
      "exec": "echo \" $(playerctl metadata --format '{{title}} - {{artist}}' 2>/dev/null || echo 'No music') \"",
      "interval": 1,
      "tooltip": false
    },
    "custom/media-next": {
      "format": " ůįí≠ ",
      "tooltip": false,
      "on-click": "playerctl next"
    }
}
