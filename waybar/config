      "tooltip-format-disconnected": "Disconnected",
      "interval": 3,
      "nospacing": 1,
      "on-click": "alacritty -e iwctl"
    },
    "battery": {
      "format": "{capacity}% {icon}",
      "format-discharging": "{icon}",
      "format-charging":    "{icon}",
      "format-plugged":     "Ôá¶",
        "format-icons": {
          "charging": [
            "ůįĘú", "ůįāÜ", "ůįāá", "ůįāą", "ůįĘĚ", "ůįāČ", "ůįĘě", "ůįāä", "ůįāč", "ůįāÖ"
          ],
          "default": [
            "ůįĀļ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"
          ]
        },
      "format-full": "Charged ÔÉß",
      "tooltip-format-discharging": "{power:>1.0f}W‚Üď {capacity}%",
      "tooltip-format-charging": "{power:>1.0f}W‚ÜĎ {capacity}%",
      "interval": 5,
