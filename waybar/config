        "7": "7",
        "8": "8",
        "9": "9",
        "active": "ůĪďĽ"
      },
      "persistent-workspaces": {
        "1": []
      }
    },
    "cpu": {
      "interval": 5,
      "format": "ůįćõ",
      "on-click": "alacritty -e btop"
    },
    "clock": {
      "format": "{:%A %I:%M %p}",
      "format-alt": "{:%d %B W%V %Y}",
      "tooltip": false
    },
    "network": {
      "format-icons": ["ůį§Į","ůį§ü","ůį§Ę","ůį§•","ůį§®"],
