{
  "layer": "top",
    "position": "top",
    "spacing": 0,
    "height": 26,
    "modules-left": [
      "hyprland/workspaces"
    ],
    "modules-center": [
      "group/media",
      "clock"
    ],
    "modules-right": [
      "group/tray-expander",
      "bluetooth",
      "network",
      "pulseaudio",
      "cpu",
      "battery",
      "group/power-menu"
    ],
    "hyprland/workspaces": {
