        "critical": 10
      }
    },
    "bluetooth": {
      "format": "ÔäĒ",
      "format-disabled": "ůįā≤",
      "format-connected": "ÔäĒ",
      "tooltip-format": "Devices connected: {num_connections}",
      "on-click": "GTK_THEME=Adwaita-dark blueberry"
    },
    "pulseaudio": {
      "format": "ÔÄ¶",
      "format-muted": "ůįĚü",
      "scroll-step": 5,
      "on-click": "GTK_THEME=Adwaita-dark pavucontrol",
      "tooltip-format": "Playing at {volume}%",
      "on-click-right": "pamixer -t",
      "ignored-sinks": ["Easy Effects Sink"]
    },
    "group/tray-expander": {
      "orientation": "inherit",
      "drawer": {
        "transition-duration": 600,
        "children-class": "tray-group-item"
      },
      "modules": [
        "custom/expand-icon",
        "tray"
      ]
    },
    "custom/expand-icon": {
      "format": "Ôāč ",
      "tooltip": false
    },
    "tray": {
      "icon-size": 12,
      "spacing": 12
    },
    "group/power-menu": {
      "orientation": "inherit",
      "drawer": {
        "transition-duration": 600,
        "children-class": "power-group-item"
      },
      "modules": [
        "custom/power-icon",
        "custom/shutdown",
        "custom/restart",
        "custom/suspend",
        "custom/lock"
      ]
    },
    "custom/power-icon": {
      "format": "ůĪźč ",
      "tooltip": false
    },
    "custom/lock": {
      "format": "Ó©Ķ ",
      "tooltip": false,
      "on-click": "hyprlock"
    },
    "custom/shutdown": {
      "format": "ÔÄĎ ",
      "tooltip": false,
      "on-click": "systemctl poweroff"
    },
    "custom/restart": {
      "format": "Óęí ",
      "tooltip": false,
